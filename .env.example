# Pengaturan API Indodax
# Dapatkan di: https://indodax.com/profile/api_keys
INDODAX_API_KEY=masukkan_api_key_anda_di_sini
INDODAX_SECRET_KEY=masukkan_secret_key_anda_di_sini

# Pengaturan Koin & Trading
TRADING_PAIR=BTC/IDR
TIMEFRAME=1h
# Nominal Beli dalam Rupiah (contoh: Rp 50.000)
BUY_AMOUNT_IDR=50000 

# Pengaturan Telegram Bot (Opsional)
# Buat bot dari @BotFather di Telegram untuk mendapatkan Token
TELEGRAM_BOT_TOKEN=masukkan_token_bot_anda_di_sini
# Dapatkan Chat ID Anda (bisa melalui @userinfobot)
TELEGRAM_CHAT_ID=masukkan_chat_id_anda_di_sini

# Mode Operasi (Ubah ke FALSE jika ingin menggunakan uang beneran)
DRY_RUN=True
